<div class="navbar">
	<div class="container-fluid">
		<div class="col-3">
			<a class="navbar-brand" href="#">
				<img src="/images/UltimaWhite.png" alt="Logo" height="40" class="d-none d-md-block">
				<img src="/images/LogoWhite.png" alt="Logo" height="50" class="d-md-none">
			</a>
		</div>

		<div class="col col-md-4">
			<div class="@NavMenuCssClass">
				<div class="row flex-row justify-content-between align-items-center">
					<div class="nav-item col-3">
						<NavLink class="nav-link text-center" href="" Match="NavLinkMatch.All">
							<span class="" aria-hidden="true">Home</span>
						</NavLink>
					</div>
					<div class="nav-item col-3">
						<NavLink class="nav-link" href="about">
							<span class="" aria-hidden="true">About</span>
						</NavLink>
					</div>
					<div class="nav-item col-3">
						<NavLink class="nav-link" href="shop">
							<span class="" aria-hidden="true">Shop</span>
						</NavLink>
					</div>
				</div>
			</div>
		</div>

		<div class="col-3">
			<button title="Navigation menu" class="navbar-toggler d-md-none float-end" @onclick="ToggleNavMenu">
				<span class="navbar-toggler-icon"></span>
			</button>
		</div>

	</div>
</div>


@code {
	private bool collapseNavMenu = false;

	private string? NavMenuCssClass => collapseNavMenu ? "d-md-none position-absolute start-50 translate-middle-x" : "d-none d-md-block";

	private void ToggleNavMenu()
	{
			collapseNavMenu = !collapseNavMenu;
	}
}
