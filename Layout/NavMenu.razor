<nav class="site-nav">
    <div class="nav-inner">

        <a class="nav-logo" href="/">ULTIMA</a>

        <ul class="nav-links">
            <li><a href="#hero" class="@(currentSection == "hero" ? "active" : "")">Home</a></li>
            <li><a href="#about" class="@(currentSection == "about" ? "active" : "")">About</a></li>
            <li><a href="#shop" class="@(currentSection == "shop" ? "active" : "")">Shop</a></li>
        </ul>

        <a href="https://open.spotify.com/artist/16covOFVavN0LYXTOcu86z"
           target="_blank"
           class="nav-cta">Listen Now</a>

        <button class="hamburger @(isOpen ? "is-open" : "")"
                @onclick="ToggleMenu"
                aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
    </div>

    <div class="mobile-drawer @(isOpen ? "is-open" : "")">
        <ul>
            <li><a href="#hero"  @onclick="CloseMenu">Home</a></li>
            <li><a href="#about" @onclick="CloseMenu">About</a></li>
            <li><a href="#shop"  @onclick="CloseMenu">Shop</a></li>
            <li><a href="https://open.spotify.com/artist/16covOFVavN0LYXTOcu86z"
                   target="_blank" @onclick="CloseMenu">Listen Now</a></li>
        </ul>
    </div>

    @if (isOpen)
    {
        <div class="nav-backdrop" @onclick="CloseMenu"></div>
    }
</nav>

@code {
    private bool isOpen = false;
    private string currentSection = "hero";

    private void ToggleMenu() => isOpen = !isOpen;
    private void CloseMenu()  => isOpen = false;
}