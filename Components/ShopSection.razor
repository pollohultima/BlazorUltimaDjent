@using BlazorUltimaDjent.Models
@using BlazorUltimaDjent.Services
@inject ProductService ProductService
@inject IJSRuntime JS

<section id="shop" class="shop-section">
    <div class="shop-header">
        <div class="section-label reveal">Merch</div>
        <h2 class="section-title reveal reveal-delay-1">LABEL AS AN<br />ULTIM8</h2>
    </div>
    @if (Products == null)
    {
        <div class="shop-loading"><span class="loading-text">LOADING PRODUCTS...</span></div>
    }
    else if (!Products.Any())
    {
        <p class="shop-empty">No products available right now.</p>
    }
    else
    {
        <div class="shop-grid">
            @foreach (var product in Products)
            {
                <ProductCard Data="@product" OnAddToCart="AddToCart" />
            }
        </div>
    }
</section>

@code {
    private List<Product>? Products;

    protected override async Task OnInitializedAsync()
    {
        Products = await ProductService.GetProductsAsync();
    }

    // Re-run initReveal AFTER products finish loading and Blazor re-renders
    // This is like a callback after an async operation completes in C#
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initReveal");
    }

    private void AddToCart(Product p)
    {
        Console.WriteLine($"Added to cart: {p.Title}");
    }
}