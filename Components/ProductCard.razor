@using BlazorUltimaDjent.Models

<div class="product-card reveal">
    @if (!string.IsNullOrEmpty(Data.Tag))
    {
        <span class="product-tag @(Data.Tag == "New" ? "tag-new" : "tag-sold")">@Data.Tag</span>
    }

    <div class="product-img">
        @if (!string.IsNullOrEmpty(Data.ImageSource))
        {
            <img src="@Data.ImageSource" alt="@Data.Title" />
        }
        else
        {
            <span class="img-placeholder">NO IMAGE</span>
        }
    </div>

    <div class="product-info">
        <div class="product-name">@Data.Title</div>
        <div class="product-desc">@Data.Description</div>
        <div class="product-footer">
            <span class="product-price">€ @Data.Price</span>
            <button class="product-buy"
                    disabled="@(Data.Tag == "Sold Out")"
                    @onclick="() => OnAddToCart.InvokeAsync(Data)">
                @(Data.Tag == "Sold Out" ? "Sold Out" : "Add to Cart")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public Product Data { get; set; } = new();

    // EventCallback is Blazor's equivalent of a C# Action<T> delegate
    // It lets the parent (Shop.razor) react when the button is clicked
    [Parameter]
    public EventCallback<Product> OnAddToCart { get; set; }
}