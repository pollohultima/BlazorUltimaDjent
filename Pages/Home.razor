@page "/"
@using BlazorUltimaDjent.Components
@inject IJSRuntime JS

<PageTitle>Ultima — Bloom The Ego</PageTitle>

<Hero />
<SpotifyPlayer />

@* About section inline — same markup as About.razor but no @page directive *@
<section id="about" class="about-section">
    <div class="about-watermark">ULTIMA</div>
    <div class="about-grid">
        <div class="about-image-wrap reveal">
            <img src="/images/ULTIMA2025.jpg" alt="Ultima Band" class="about-img" />
            <div class="bracket tl"></div>
            <div class="bracket tr"></div>
            <div class="bracket bl"></div>
            <div class="bracket br"></div>
        </div>
        <div class="about-text">
            <div class="section-label reveal">The Band</div>
            <h1 class="section-title reveal reveal-delay-1">BORN FROM<br />RIFFS &amp;<br />PIXELS</h1>
            <div class="reveal reveal-delay-2">
                <p><strong>Ultima</strong> was born from two obsessions: heavy riffs and videogames.</p>
                <p>Founded in <strong>2016</strong>, the band grew into a full five-piece djent force.</p>
                <p>The debut album <strong>"Bloom The Ego"</strong> is now on every platform.</p>
                <p>FFO: <strong>Periphery, Monuments, Volumes, Tesseract.</strong></p>
            </div>
            <div class="about-stats reveal reveal-delay-3">
                <div class="stat-box"><span class="stat-num">2016</span><span class="stat-label">Founded</span></div>
                <div class="stat-box"><span class="stat-num">30K+</span><span class="stat-label">Views</span></div>
                <div class="stat-box"><span class="stat-num">3+</span><span class="stat-label">Countries</span></div>
            </div>
        </div>
    </div>
</section>

@* Shop section inline *@
<ShopSection />